<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Gallery | AL Hind Educational and Charitable Trust</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <meta name="description" content="Explore photos from our education, welfare, and community development programs.">

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/gallery.css">
</head>

<body>

    <!-- HEADER -->
    <div id="header"></div>

    <!-- BREADCRUMB -->
    <section class="breadcrumb">
        <div class="container">
            <a href="index.html">Home</a> /
            <span>Gallery</span>
        </div>
    </section>

    <!-- PAGE HERO -->
    <section>
        <h1 class="section-title">Our Work in Action</h1>
        <p style="max-width:700px;margin:auto;color:#64748b;">
            Moments from our educational programs, health camps, community outreach,
            and volunteer activities.
        </p>
    </section>
    <!-- CAROUSEL -->
    <section class="gallery-carousel">
        <button class="carousel-btn prev">‹</button>
    
        <div class="carousel-track">
            <div class="carousel-slide">
                <img src="/assets/gallery/1.jpeg" alt="Education Program">
                <p>Education Support Program</p>
            </div>
            <div class="carousel-slide">
                <img src="/assets/gallery/3.jpeg" alt="Health Camp">
                <p>Free Medical Camp</p>
            </div>
        </div>
    
        <button class="carousel-btn next">›</button>
    </section>


    <!-- GALLERY GRID -->
    <section class="section">
        <div class="gallery-grid container">

            <!-- ITEM -->
            <div class="gallery-item skeleton">
                <img src="/assets/gallery/1.jpeg" alt="Education Program" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>

            <div class="gallery-item skeleton">
                <img src="/assets/gallery/7.jpeg" alt="Classroom Activity" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>

            <div class="gallery-item skeleton">
                <img src="/assets/gallery/3.jpeg" alt="Community Outreach" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>

            <div class="gallery-item skeleton">
                <img src="/assets/gallery/4.jpeg" alt="Health Camp" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>

            <div class="gallery-item skeleton">
                <img src="/assets/gallery/5.jpeg" alt="Volunteer Activity" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>

            <div class="gallery-item skeleton">
                <img src="/assets/gallery/6.jpeg" alt="Distribution Drive" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>

            <div class="gallery-item skeleton">
                <img src="/assets/gallery/8.jpeg" alt="Skill Development" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>
            <div class="gallery-item skeleton">
                <img src="/assets/gallery/9.jpeg" alt="Awareness Campaign" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>

            <div class="gallery-item skeleton">
                <img src="/assets/gallery/10.jpeg" alt="Health Camp" loading="lazy" decoding="async"
                    class="skeleton-hidden">
            </div>

        </div>
    </section>

    <!-- LIGHTBOX -->
    <div id="lightbox">
        <span class="lightbox-close">&times;</span>
        <img class="lightbox-img" alt="">
    </div>

    <!-- FOOTER -->
    <div id="footer"></div>

    <!-- SCRIPTS -->
    <script src="js/include.js" defer></script>
    <script src="js/main.js" defer></script>
    <script src="js/header-animate.js" defer></script>
    <script src="js/gallery.js" defer></script>

</body>

</html>